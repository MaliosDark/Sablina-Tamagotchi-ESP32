// ═══════════════════════════════════════════════════════════════════
//  secrets.h, Credentials for the Telegram bot + OpenWebUI API
//  ─────────────────────────────────────────────────────────────────
//  HOW TO USE:
//    1. Copy this file to secrets.h  (same folder)
//       cp secrets.h.example secrets.h
//    2. Fill in your values below
//    3. Compile and flash, the values are saved to NVS and survive
//       future compilations even if you remove or empty this file.
//
//  This file (secrets.h) is listed in .gitignore and will never
//  be committed to the repository.
// ═══════════════════════════════════════════════════════════════════

// Telegram bot token, get one from https://t.me/BotFather
#define TG_BOT_TOKEN_DEFAULT        "YOUR_TELEGRAM_BOT_TOKEN"

// OpenWebUI API key, Account → API Keys on your OpenWebUI instance
#define TG_OPENWEBUI_KEY_DEFAULT    "sk-your-openwebui-api-key"

// OpenWebUI completions endpoint
#define TG_OPENWEBUI_ENDPOINT_DEFAULT  "https://your-openwebui-server/api/chat/completions"

// Model to use (must be available on your OpenWebUI instance)
#define TG_OPENWEBUI_MODEL_DEFAULT     "llama3.2:latest"

// Canvas / Platform integration
#define CANVAS_URL_DEFAULT   "https://your-canvas-server"
#define CANVAS_KEY_DEFAULT   "sk-sablina-your-api-key"
